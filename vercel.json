{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/blog/:slug", "destination": "/post" }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    }
  ]
}
